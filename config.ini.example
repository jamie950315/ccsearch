[Brave]
# Rate limiting: Maximum number of requests allowed per second.
# Prevents getting banned. Set according to your API tier (e.g., 1 for free tier).
requests_per_second = 1

# Number of search results to return per query (max 20 for free tier, default is 10).
count = 10

# Content filtering level for search results.
# Allowed values: off, moderate, strict
safesearch = moderate

# Time-based filtering (how recent the results should be).
# Allowed values:
#   (leave blank for no limit)
#   pd (Past 24 hours)
#   pw (Past week)
#   pm (Past month)
#   py (Past year)
freshness =

# Number of times to auto-retry the request if a timeout or network error occurs.
# Uses exponential backoff (e.g., waits 1s, 2s, 4s before trying again).
max_retries = 2

[Perplexity]
# The specific language model to use via OpenRouter for generating answers.
# Examples: perplexity/sonar, perplexity/sonar-pro
model = perplexity/sonar

# If true, forces the system prompt to instruct the model to include markdown citations (e.g., [1], [2]).
citations = true

# Controls the randomness of the output. Range: 0.0 to 1.0.
# Lower values (e.g., 0.1) make the output more deterministic and factual.
temperature = 0.1

# Hard limit for the maximum number of tokens to generate in the response.
# Useful for controlling API costs and generation time.
max_tokens = 1024

# Number of times to auto-retry the request if a timeout or network error occurs.
# Uses exponential backoff.
max_retries = 2

[LLMContext]
# Number of search results to consider for context extraction (1-50).
count = 20

# Approximate maximum tokens in the context response (1024-32768).
# Lower for simple factual queries, higher for complex research.
#   Simple factual:  2048  (e.g. "What year was Python created?")
#   Standard:        8192  (e.g. "React hooks best practices")
#   Deep research:  16384  (e.g. "Compare AI frameworks for production")
maximum_number_of_tokens = 8192

# Maximum URLs in the response (1-50).
maximum_number_of_urls = 20

# Relevance threshold for including content.
# Allowed values: strict, balanced, lenient, disabled
#   strict   = fewer but more precise results
#   balanced = default, good coverage vs relevance
#   lenient  = more results, may include less relevant content
#   disabled = no filtering, return all extracted content
context_threshold_mode = balanced

# Time-based filtering (same values as Brave: pd, pw, pm, py, or blank).
freshness =

# Number of times to auto-retry on timeout or network error.
max_retries = 2

[Fetch]
# FlareSolverr proxy URL for bypassing Cloudflare and rendering JS-heavy pages.
# Leave blank to disable the fallback (only bare HTTP requests will be used).
# Requires a running FlareSolverr instance (Docker recommended).
# Example: http://localhost:8191/v1 or http://pi5.tailnet:8191/v1
flaresolverr_url =

# Maximum time (ms) to wait for FlareSolverr to solve a challenge.
flaresolverr_timeout = 60000

# Strategy: "fallback" = try requests.get first, use FlareSolverr only on failure.
#           "always"   = always use FlareSolverr for every fetch request.
#           "never"    = never use FlareSolverr even if configured.
flaresolverr_mode = fallback

# SPA auto-detection: When flaresolverr_mode = fallback, the fetch engine automatically
# detects JS-heavy SPA shells (empty mount points like <div id="root">, script-heavy pages
# with little text) and falls back to FlareSolverr for headless rendering.
# No configuration needed — detection is based on HTML structure, not a fixed char threshold.

[Batch]
# Maximum number of worker threads used by batch execution.
# Increase for network-heavy workloads; keep modest to avoid exhausting rate limits.
max_workers = 4
